generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique
  active             Boolean              @default(true)
  sub_order          Int?                 // null = regular player; 1–N = sub priority order
  rounds             Round[]
  prior_averages     PriorSeasonAverage[]
  game_team_members  GameTeamMember[]
  putt_off_games     Game[]
}

model PriorSeasonAverage {
  id          Int    @id @default(autoincrement())
  player_id   Int
  season_year Int
  average     Float
  player      Player @relation(fields: [player_id], references: [id])

  @@unique([player_id, season_year])
}

model Season {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  start_date DateTime
  end_date   DateTime
  rounds     Round[]
}

model Round {
  id              Int         @id @default(autoincrement())
  player_id       Int
  season_id       Int
  week_number     Int
  date            DateTime
  course_half     String      // "front9" | "back9"
  total_score     Int
  has_hole_scores Boolean     @default(false)
  notes           String?
  player          Player      @relation(fields: [player_id], references: [id])
  season          Season      @relation(fields: [season_id], references: [id])
  hole_scores     HoleScore[]

  @@unique([player_id, week_number, season_id])
}

model HoleScore {
  id          Int   @id @default(autoincrement())
  round_id    Int
  hole_number Int
  strokes     Int
  round       Round @relation(fields: [round_id], references: [id], onDelete: Cascade)

  @@unique([round_id, hole_number])
}

model Game {
  id                   Int        @id @default(autoincrement())
  name                 String
  date                 DateTime
  ruleset_type         String     // "BEST_BALL"
  is_major             Boolean    @default(false)
  status               String     @default("PENDING") // "PENDING" | "COMPLETE"
  putt_off_winner_id   Int?
  putt_off_winner      Player?    @relation(fields: [putt_off_winner_id], references: [id])
  calculated_at        DateTime?
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt
  teams                GameTeam[]
}

model GameTeam {
  id        Int              @id @default(autoincrement())
  game_id   Int
  name      String
  points    Int?
  is_winner Boolean          @default(false)
  game      Game             @relation(fields: [game_id], references: [id], onDelete: Cascade)
  members   GameTeamMember[]
}

model GameTeamMember {
  id           Int      @id @default(autoincrement())
  game_team_id Int
  player_id    Int
  is_sub       Boolean  @default(false)
  team         GameTeam @relation(fields: [game_team_id], references: [id], onDelete: Cascade)
  player       Player   @relation(fields: [player_id], references: [id])

  @@unique([game_team_id, player_id])
}
